{
  "name": "superhot-ui",
  "version": "0.1.0",
  "description": "SUPERHOT-inspired visual effects for dashboards — CSS-first with JS utilities and Preact components",
  "type": "module",
  "exports": {
    "./css": "./dist/superhot.css",
    "./tokens": "./css/tokens.css",
    ".": "./dist/superhot.js",
    "./preact": "./dist/superhot.preact.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:css": "cp css/superhot.css dist/superhot.css",
    "test": "node --test tests/**/*.test.js",
    "dev": "node esbuild.config.mjs --watch",
    "prepare": "husky"
  },
  "peerDependencies": {
    "preact": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "cspell": "^9.7.0",
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "preact": "^10.25.0",
    "prettier": "^3.8.1"
  },
  "files": [
    "css/",
    "js/",
    "preact/",
    "dist/"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,mjs,css,json,md}": "prettier --write"
  }
}
