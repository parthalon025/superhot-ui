{
  "name": "superhot-ui",
  "version": "0.2.0",
  "style": "css/superhot.css",
  "description": "SUPERHOT-inspired visual effects for dashboards — CSS-first with JS utilities and Preact components",
  "type": "module",
  "exports": {
    "./css": "./dist/superhot.css",
    "./tokens": "./css/tokens.css",
    ".": "./dist/superhot.js",
    "./preact": "./dist/superhot.preact.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:css": "cp css/superhot.css dist/superhot.css",
    "test": "node --test tests/**/*.test.js",
    "dev": "node esbuild.config.mjs --watch",
    "prepare": "husky",
    "lint": "eslint .",
    "test:browser": "playwright test",
    "test:all": "node --test 'tests/*.test.js' && playwright test"
  },
  "peerDependencies": {
    "@preact/signals": "^2.0.0",
    "preact": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@preact/signals": "^2.8.2",
    "cspell": "^9.7.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.21.0",
    "preact": "^10.25.0",
    "prettier": "^3.8.1"
  },
  "files": [
    "css/",
    "js/",
    "preact/",
    "dist/",
    "scripts/",
    "docs/"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,mjs,css,json,md}": "prettier --write"
  }
}
