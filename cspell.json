{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules",
    ".venv",
    "dist",
    "build",
    "coverage",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "*.min.js",
    "*.min.css",
    ".embeddings"
  ],
  "words": [],
  "dictionaries": ["typescript", "python", "bash", "npm"],
  "overrides": [
    {
      "filename": "**/*.sh",
      "dictionaries": ["bash"]
    }
  ]
}
